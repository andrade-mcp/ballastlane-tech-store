# Copy to /home/ubuntu/ballastlane-tech-store/.env on the VM and fill in real values.
# This file is read by docker compose when running with the prod overlay.

# JWT signing key — must be at least 32 bytes (HS256 minimum). Generate with:
#   openssl rand -base64 48 | tr -d '\n'
JWT_SIGNING_KEY=replace-me-with-a-secure-48-byte-base64-string

# Public origins as Cloudflare Tunnel will route them. No trailing slash.
PUBLIC_WEB_ORIGIN=https://ballastlane-tech.store
PUBLIC_AUTH_API_ORIGIN=https://auth.ballastlane-tech.store
PUBLIC_STORE_API_ORIGIN=https://api.ballastlane-tech.store
